plot_res <- 150
open_png <- function(filename, width = 10.5, height = 7.5, res = plot_res) {
  if (capabilities("cairo")) {
    png(filename, width = width, height = height, units = "in",
        res = res, type = "cairo", bg = "white")
  } else {
    png(filename, width = width, height = height, units = "in",
        res = res, bg = "white")
  }
}

apply_plot_style <- function() {
  old <- par(no.readonly = TRUE)
  par(
    mar = c(4.2, 4.6, 2.4, 1.4),
    mgp = c(2.2, 0.7, 0),
    tcl = -0.3,
    las = 1,
    cex.axis = 1.0,
    cex.lab = 1.1,
    cex.main = 1.2
  )
  old
}

save_base_plot <- function(filename, width = 10.5, height = 7.5, res = plot_res, expr) {
  open_png(filename, width = width, height = height, res = res)
  opar <- apply_plot_style()
  on.exit({
    par(opar)
    dev.off()
  }, add = TRUE)
  eval(substitute(expr), envir = parent.frame())
}

build_lfq <- function(df, date_col = NULL, date_start_col = 2) {
  # date_col: if your data has a column with dates, give its name or index
  # date_start_col: if dates are in column names, the first column index that is NOT a date (default 1 = midLengths, so dates start at 2)
  if (!requireNamespace("lubridate", quietly = TRUE)) {
    stop("Please install the 'lubridate' package: install.packages('lubridate')")
  }
  # copy to avoid side effects
  d <- df
  
  # Clean column names
  nm <- names(d)
  nm_clean <- trimws(nm)
  nm_clean <- gsub("^X", "", nm_clean)        # remove leading X
  nm_clean <- gsub("\\.", "/", nm_clean)      # dots -> slashes
  nm_clean <- gsub("-", "/", nm_clean)        # hyphens -> slashes
  names(d) <- nm_clean
  
  # If the user specified a date column, parse that
  if (!is.null(date_col)) {
    colname <- if (is.numeric(date_col)) names(d)[date_col] else as.character(date_col)
    raw_dates <- as.character(d[[colname]])
    parsed <- lubridate::dmy(raw_dates)
    if (all(is.na(parsed))) parsed <- lubridate::ymd(raw_dates)
    if (all(is.na(parsed))) parsed <- lubridate::mdy(raw_dates)
    if (all(is.na(parsed))) parsed <- as.Date(raw_dates, tryFormats = c("%Y-%m-%d", "%d/%m/%Y", "%m/%d/%Y"))
    dates <- parsed
    # remove date column from catch if necessary
    catch_cols <- setdiff(seq_along(d), which(names(d) == colname))
    midLengths <- d[[1]]
    catch <- as.matrix(d[, catch_cols, drop = FALSE])
  } else {
    # Dates are in column names: detect date-like names
    # Heuristic: names that match dd/mm/yyyy or d/m/yyyy or yyyy/mm/dd
    is_date_like <- grepl("^\\s*\\d{1,4}[/\\.\\-]\\d{1,2}[/\\.\\-]\\d{2,4}\\s*$", names(d))
    # If none detected, assume dates start at date_start_col
    if (!any(is_date_like)) {
      date_names <- names(d)[date_start_col:ncol(d)]
    } else {
      date_names <- names(d)[is_date_like]
    }
    # parse date names
    date_names_char <- as.character(date_names)
    parsed <- lubridate::dmy(date_names_char)
    if (all(is.na(parsed))) parsed <- lubridate::ymd(date_names_char)
    if (all(is.na(parsed))) parsed <- lubridate::mdy(date_names_char)
    # final fallback
    if (all(is.na(parsed))) parsed <- as.Date(date_names_char, tryFormats = c("%Y/%m/%d", "%d/%m/%Y", "%m/%d/%Y", "%Y-%m-%d"))
    # warn if some failed
    if (any(is.na(parsed))) {
      warning("Some column-name dates failed to parse: ",
              paste(date_names_char[is.na(parsed)], collapse = ", "))
    }
    dates <- parsed
    # build midLengths and catch matrix
    midLengths <- d[[1]]
    # determine which columns correspond to the date_names (use positions)
    date_positions <- which(names(d) %in% date_names_char)
    catch <- as.matrix(d[, date_positions, drop = FALSE])
    # ensure column names of catch are the parsed dates (character)
    colnames(catch) <- as.character(dates)
  }
  
  # Final checks
  if (length(dates) != ncol(catch)) {
    warning("Number of parsed dates (", length(dates), ") does not match number of catch columns (", ncol(catch), ").")
  }
  
  lfqnew <- list(
    dates = as.Date(dates),
    midLengths = midLengths,
    catch = catch
  )
  class(lfqnew) <- "lfq"
  lfqnew
}

subset_lfq_dates <- function(lfq, start_date, end_date) {
  idx <- lfq$dates >= start_date & lfq$dates <= end_date
  lfq$dates <- lfq$dates[idx]
  lfq$catch <- lfq$catch[, idx, drop = FALSE]
  lfq
}

compute_bounds <- function(lfq_bin, linf_mult, k_range) {
  linf_guess <- max(lfq_bin$midLengths) / 0.95   # set Lmax/0.95 as prior of Linf
  low_par <- list(
    Linf = linf_mult[1] * linf_guess,
    K = k_range[1],
    t_anchor = t_anchor_range[1], # time point anchoring growth curves in year-length coordinate system, corresponds to peak spawning month (range: 0 to 1, default: 0.25)
    C = 0, # amplitude of growth oscillation (range: 0 to 1, default: 0)
    ts = 0  # (ts = WP - 0.5) (range: 0 to 1, default: 0)
  )
  up_par <- list(
    Linf = linf_mult[2] * linf_guess,
    K = k_range[2],
    t_anchor = t_anchor_range[2],
    C = 0,
    ts = 0
  )
  list(linf_guess = linf_guess, low_par = low_par, up_par = up_par)
}

summarise_boot <- function(res_GA) {
  pars_median <- as.list(apply(res_GA$bootRaw[, c("Linf", "K", "t_anchor")], 2, median))
  pars <- data.frame(method = "median", as.list(pars_median))
  pars$t0 <- -(1 - pars$t_anchor)
  pars
}

make_vbgf_curve <- function(pars_row, age = age_grid) {
  FLCore::vonbert(pars_row$Linf, pars_row$K, pars_row$t0, age)
}

plot_raw_restructured <- function(lfq_res, out_file) {
  save_base_plot(out_file, height = 8.5, expr = {
    par(mfrow = c(2, 1), mar = c(2.2, 5.0, 2.0, 1.5), oma = c(2, 0, 0, 0))
    plot(lfq_res, Fname = "catch", date.axis = "modern")
    plot(lfq_res, Fname = "rcounts", date.axis = "modern")
  })
}

plot_fits <- function(lfq_bin, lfq_res, res_GA, out_fit, out_resid) {
  save_base_plot(out_resid, expr = {
    plot(lfq_res, Fname = "rcounts", date.axis = "modern")
  })

  save_base_plot(out_fit, expr = {
    plot(lfq_res, Fname = "catch", date.axis = "modern")
    lfqFitCurves(lfq_bin, par = res_GA$par, draw = TRUE, col = "green4", lty = 1, lwd = 0.8)
  })
}

plot_final_curve <- function(res_GA, out_file, age = age_grid) {
  Linf <- res_GA$par$Linf
  K    <- res_GA$par$K
  t0   <- -(1 - res_GA$par$t_anchor)

  eq <- paste0("Linf=", round(Linf), "; k=", round(K, 2), "; t0=", round(t0, 2))

  save_base_plot(out_file, width = 8.5, height = 6.5, expr = {
    plot(
      age, Linf * (1 - (exp(-K * (age - t0)))),
      main = eq, type = "o", pch = 19, lwd = 2,
      col = "green4", ylab = "Length (cm)", xlab = "Age (years)"
    )
    grid(col = "gray45", lty = 0.5)
  })
}

