#5.1 ELEFAN METHODS (NO BOOTSTRAP)

```{r}
run_elefan_workflow <- function(file, gsa, period, P1, P2, species, sex) {
  
  df <- input_data[[file]]
  if (is.null(df)) {
    stop("Input file not found in input_data: ", file)
  }

  lfq_raw <- build_lfq(df)

  # Subset period
  lfq_win <- subset_lfq_dates(lfq_raw, P1, P2)

  # Modify bin & restructure
  lfq_bin <- lfqModify(lfq_win, bin_size = bin_size)
  lfq_res <- lfqRestructure(lfq_bin)

  name <- paste0(species, "_", sex, "_GSA", gsa, "_", period)

  # Save raw vs restructured
  plot_raw_restructured(
    lfq_res,
    file.path(output_dir, paste0(name, "_raw_data.png"))
  )

  # Parameter bounds
  bounds <- compute_bounds(lfq_bin, linf_mult, k_range)

  # -----------------------------
  # ELEFAN METHODS (NO BOOTSTRAP)
  # -----------------------------
  # GA (main method)
  res_GA <- ELEFAN_GA(
    lfq_bin,
    MA = ma,
    seasonalised = seasonalised,
    addl.sqrt = addl_sqrt,
    low_par = bounds$low_par,
    up_par  = bounds$up_par,
    pcrossover = pcrossover,
    popSize = popSize,
    maxiter = maxiter,
    parallel = parallel
  )

  # Simulated Annealing
  res_SA <- ELEFAN_SA(
    lfq_bin,
    MA = ma,
    seasonalised = seasonalised,
    addl.sqrt = addl_sqrt,
    low_par = bounds$low_par,
    up_par  = bounds$up_par
  )

  # Classic ELEFAN
  res_classic <- ELEFAN(
    lfq_bin,
    MA = ma,
    cross.max = TRUE,
    contour = TRUE,
    K_range = exp(seq(log(0.1), log(10), length.out = 100))) #seq(k_range[1], k_range[2], length.out = 20)
 
  # -----------------------------
  # PLOTS
  # -----------------------------
  # GA fit (main result)
  plot_fits(
    lfq_bin, lfq_res, res_GA,
    out_fit = file.path(output_dir, paste0(name, "_fit_GA.png")),
    out_resid = file.path(output_dir, paste0(name, "_residuals_GA.png"))
  )

  # Comparison plot
  save_base_plot(file.path(output_dir, paste0(name, "_compare_methods.png")), expr = {
    plot(lfq_res, Fname = "catch", date.axis = "modern")

    lfqFitCurves(lfq_bin, par = res_GA$par,
                 draw = TRUE, col = "blue", lwd = 1)

    lfqFitCurves(lfq_bin, par = res_SA$par,
                 draw = TRUE, col = "red", lty = 2)

    lfqFitCurves(lfq_bin, par = res_classic$par,
                 draw = TRUE, col = "black", lty = 3)

    legend("bottomright",
           legend = c("GA", "SA", "Classic"),
           col = c("blue", "red", "black"),
           lty = c(1,2,3),
           bty = "n")
  })

  # Final VBGF curve (GA only)
  plot_final_curve(
    res_GA,
    file.path(output_dir, paste0(name, "_VBGF.png"))
  )

  # -----------------------------
  # SAVE RESTRUCTURED DATA
  # -----------------------------

  lfq_res_df <- data.frame(midLength = lfq_res$midLengths, lfq_res$rcounts)
  colnames(lfq_res_df)[-1] <- format(lfq_res$dates, "%Y-%m-%d")

  write.csv(
    lfq_res_df,
    file.path(output_dir, paste0(name, "_lfq_res.csv")),
    row.names = FALSE
  )
  # -----------------------------
  # RETURN RESULTS
  # -----------------------------
  list(
    name = name,
    gsa = gsa,
    period = period,
    res_GA = res_GA,
    res_SA = res_SA,
    res_classic = res_classic,
    lfq_bin = lfq_bin,
    lfq_res = lfq_res
  )
}

